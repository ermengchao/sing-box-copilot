{
  "dns": {
    "rules": [
      {
        "domain_suffix": [
          "arpa"
        ],
        "action": "route",
        "server": "dns-dhcp"
      },
      {
        "domain_suffix": [
          "ts.net"
        ],
        "action": "route",
        "server": "dns-tailscale"
      },
      {
        "action": "evaluate",
        "server": "dns-resolved"
      },
      {
        "match_response": true,
        "ip_accept_any": true,
        "action": "respond"
      },
      {
        "clash_mode": "direct",
        "action": "route",
        "server": "dns-local"
      },
      {
        "clash_mode": "global",
        "action": "route",
        "server": "dns-fakeip"
      },
      {
        "rule_set": [
          "geosite-cn",
          "direct_chao",
          "direct",
          "apple",
          "china_max",
          "download",
          "lan"
        ],
        "action": "route",
        "server": "dns-local"
      },
      {
        "rule_set": [
          "claude",
          "copilot",
          "gemini",
          "openai",
          "game_chao",
          "game",
          "disney",
          "netflix",
          "hbo_usa",
          "spotify",
          "tiktok",
          "youtube",
          "youtube_music",
          "proxy_chao",
          "developer",
          "amazon_cloud",
          "apple_proxy",
          "google",
          "github",
          "global"
        ],
        "action": "route",
        "server": "dns-fakeip"
      },
      {
        "inbound": [
          "socks-in",
          "http-in",
          "tun-in"
        ],
        "action": "route",
        "server": "dns-fakeip"
      }
    ],
    "servers": [
      {
        "tag": "dns-hosts",
        "type": "hosts"
      },
      {
        "tag": "dns-resolved",
        "type": "resolved",
        "service": "services-resolved",
        "accept_default_resolvers": false
      },
      {
        "tag": "dns-local",
        "type": "local"
      },
      {
        "tag": "dns-dhcp",
        "type": "dhcp"
      },
      {
        "tag": "dns-fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      },
      {
        "tag": "dns-tailscale",
        "type": "tailscale",
        "endpoint": "endpoints-tailscale",
        "accept_default_resolvers": false
      },
      {
        "tag": "doh-cloudflare",
        "type": "h3",
        "server": "dns.cloudflare.com",
        "path": "/dns-query",
        "domain_resolver": "dns-cloudflare",
        "detour": "🌐 Proxy"
      },
      {
        "tag": "doh-google",
        "type": "h3",
        "server": "dns.google",
        "path": "/dns-query",
        "domain_resolver": "dns-google",
        "detour": "🌐 Proxy"
      },
      {
        "tag": "doh-aliyun",
        "type": "h3",
        "server": "dns.alidns.com",
        "path": "/dns-query",
        "domain_resolver": "dns-aliyun"
      },
      {
        "tag": "dns-cloudflare",
        "type": "udp",
        "server": "1.1.1.1"
      },
      {
        "tag": "dns-google",
        "type": "udp",
        "server": "8.8.8.8"
      },
      {
        "tag": "dns-aliyun",
        "type": "udp",
        "server": "223.5.5.5"
      }
    ],
    "strategy": "prefer_ipv4",
    "final": "dns-local"
  },
  "endpoints": [
    {
      "tag": "endpoints-tailscale",
      "type": "tailscale",
      "state_directory": "",
      "auth_key": "",
      "control_url": "",
      "ephemeral": false,
      "hostname": "",
      "accept_routes": false,
      "exit_node": "",
      "exit_node_allow_lan_access": false,
      "advertise_routes": [],
      "advertise_exit_node": false,
      "domain_resolver": "dns-cloudflare"
    }
  ],
  "log": {
    "disabled": false,
    "level": "warn",
    "timestamp": true
  },
  "ntp": {
    "enabled": false,
    "server": "time.apple.com",
    "server_port": 123,
    "interval": "30m"
  },
  "outbounds": [
    {
      "tag": "🟢 Direct",
      "type": "direct"
    },
    {
      "tag": "🔴 Reject",
      "type": "block"
    },
    {
      "tag": "🌐 Proxy",
      "type": "selector",
      "default": "✨ Auto",
      "outbounds": [
        "✨ Auto",
        "🇯🇵 Japan 01",
        "🇯🇵 Japan 02",
        "🇯🇵 Japan 03",
        "🇯🇵 Japan 04",
        "🇯🇵 Japan 05",
        "🇯🇵 Japan 06"
      ]
    },
    {
      "tag": "✨ Auto",
      "type": "urltest",
      "outbounds": [
        "🇯🇵 Japan 01",
        "🇯🇵 Japan 02",
        "🇯🇵 Japan 03",
        "🇯🇵 Japan 04",
        "🇯🇵 Japan 05",
        "🇯🇵 Japan 06"
      ],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "300s"
    },
    {
      "tag": "📺 AD",
      "type": "selector",
      "default": "🔴 Reject",
      "outbounds": [
        "🌐 Proxy",
        "🟢 Direct",
        "🔴 Reject"
      ]
    },
    {
      "tag": "🧠 AI",
      "type": "selector",
      "default": "🔴 Reject",
      "outbounds": [
        "🌐 Proxy",
        "🟢 Direct"
      ]
    },
    {
      "tag": "🎮 Game",
      "type": "selector",
      "default": "🌐 Proxy",
      "outbounds": [
        "🌐 Proxy",
        "🟢 Direct"
      ]
    },
    {
      "tag": "🎥 Media",
      "type": "selector",
      "default": "🌐 Proxy",
      "outbounds": [
        "🌐 Proxy",
        "🟢 Direct"
      ]
    },
    {
      "tag": "🐟 Final",
      "type": "selector",
      "default": "🌐 Proxy",
      "outbounds": [
        "🌐 Proxy",
        "🟢 Direct"
      ]
    }
  ],
